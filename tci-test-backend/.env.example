# Database (PostgreSQL)
# 로컬: postgresql://user:password@localhost:5432/tci_test
# Railway: 자동 제공됨
DATABASE_URL="postgresql://user:password@localhost:5432/tci_test"

# Server
PORT=3000
NODE_ENV=development

# CORS (쉼표로 구분된 허용 도메인)
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# 프론트엔드 URL (공유 링크 생성용)
FRONTEND_URL=https://your-app.vercel.app
